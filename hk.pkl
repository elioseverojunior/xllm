amends "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
    ["check-added-large-files"] = new Step {
        glob = "**"
        check = "hk util check-added-large-files {{ files }}"
    }
    ["check-merge-conflict"] = new Step {
        glob = "**"
        check = "hk util check-merge-conflict {{ files }}"
    }
    ["check-case-conflict"] = new Step {
        glob = "**"
        check = "hk util check-case-conflict {{ files }}"
    }
    ["check-symlinks"] = new Step {
        glob = "**"
        check = "hk util check-symlinks {{ files }}"
    }
    ["check-executables-have-shebangs"] = new Step {
        glob = "**"
        check = "hk util check-executables-have-shebangs {{ files }}"
    }
    ["check-byte-order-marker"] = new Step {
        glob = "**"
        check = "hk util check-byte-order-marker {{ files }}"
    }
    ["trailing-whitespace-fixer"] = new Step {
        glob = "**"
        check = "hk util trailing-whitespace --diff {{ files }}"
        fix = "hk util trailing-whitespace {{ files }}"
    }
    ["end-of-file-fixer"] = new Step {
        glob = "**"
        check = "hk util end-of-file-fixer --diff {{ files }}"
        fix = "hk util end-of-file-fixer {{ files }}"
    }
    ["mixed-line-ending-fixer"] = new Step {
        glob = "**"
        check = "hk util mixed-line-ending --diff {{ files }}"
        fix = "hk util mixed-line-ending {{ files }}"
    }

    ["gitleaks"] = Builtins.gitleaks

    ["yamllint-rs"] = new Step {
        glob = "*.{yml,yaml}"
        check = "mise run yamllint {{ files }}"
        fix = "mise run yamllint:fix {{ files }}"
    }

    ["actionlint"] = new Step {
        glob = ".github/workflows/*.{yml,yaml}"
        check = "mise run actionlint {{ files }}"
    }

    ["cargo-sort"] = new Step {
        glob = "**/Cargo.toml"
        check = "mise run cargo-sort:check"
        fix = "mise run cargo-sort"
    }

    ["taplo"] = new Step {
        glob = "*.toml"
        check = "mise run taplo-check {{ files }}"
        fix = "mise run taplo {{ files }}"
    }

    ["rumdl"] = new Step {
        glob = "*.md"
        check = "mise run markdownlint {{ files }}"
        fix = "mise run markdownlint:fix {{ files }}"
    }

    ["reuse-fix"] = new Step {
        glob = "*.rs"
        fix = "mise run reuse:fix {{ files }}"
    }
    ["reuse-lint"] = new Step {
        glob = "**"
        check = "mise run reuse"
    }

    ["commit-config"] = new Step {
        glob = "{commit-types.toml,scripts/commit-config.py,committed.toml,cliff.toml,.gitmessage}"
        check = "mise run commit-config:check"
    }

    ["audit"] = new Step {
        glob = "{Cargo.lock,Cargo.toml,**/Cargo.toml}"
        check = "mise run audit"
    }
    ["deny"] = new Step {
        glob = "{Cargo.lock,Cargo.toml,**/Cargo.toml,deny.toml}"
        check = "mise run deny"
    }

    ["fmt-check"] = new Step {
        glob = "*.rs"
        check = "mise run fmt:check"
    }
    ["clippy"] = new Step {
        glob = "*.rs"
        check = "mise run clippy"
    }
}

hooks {
    ["pre-commit"] = {
        fix = true
        stash = "git"
        steps = linters
    }
    ["pre-commit:all"] = {
        fix = true
        stash = "git"
        steps = linters
    }
    ["check"] = {
        steps = linters
    }
    ["fix"] = {
        fix = true
        steps = linters
    }
    ["commit-msg"] = {
        steps = {
            ["committed"] = new Step {
                check = "mise run commit-lint --commit-file {{ files }}"
            }
        }
    }
    ["post-commit"] = {}
}
